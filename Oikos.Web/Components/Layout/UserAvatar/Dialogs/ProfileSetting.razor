@using Oikos.Web.Components.Layout.UserAvatar.Dialogs.Com
@using Infrastructure.Security
@using Oikos.Web.States
@using Oikos.Common.Resources



<MudDialog Gutters="false">
        <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="width:100%;">
                        <MudText Typo="Typo.h6">@Loc["AccountSettings_Title"]</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="@(() => MudDialog?.Cancel())" />
                </MudStack>
        </TitleContent>
        <DialogContent>
                <div style="width:820px;max-width:90vw;" class="pa-4">
                        <MudStack Spacing="2">
                                <BasicInfoConfig />
                        </MudStack>
                </div>
        </DialogContent>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance? MudDialog { get; set; }
}
