@using Oikos.Web.States
@using MudBlazor
@using Oikos.Common.Resources
@using Oikos.Common.Constants
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> Loc
@rendermode InteractiveServer

<MudDrawer @bind-Open="LayoutState.NavIsOpen" ClipMode="DrawerClipMode.Never" Elevation="0" Style="z-index:1350; background-color: #fafbfc; border-right: 1px solid #e0e0e0;" Width="280px" Class="navmenu__drawer">
    <div class="d-flex flex-column" style="height: 100vh;">

        @* --- HEADER: Logo --- *@
        <div class="navmenu__logo">
            <MudLink Href="/employee/dashboard" Match="NavLinkMatch.All" Class="navmenu__logo-link">
                <img src="images/rechtfix-logo.svg" alt="Rechtfix Logo" class="navmenu__logo-image" />
            </MudLink>
        </div>

        <div class="navmenu__wrapper flex-grow-1 px-3">
            <MudNavMenu Margin="Margin.None" Color="Color.Primary" Rounded="true" Class="navmenu__container">

                @* --- HOME --- *@
                @if (_permissions.Contains(EmployeePermissions.AdminHome))
                {
                    <MudNavLink Href="/employee/dashboard" Icon="@Icons.Material.Filled.Home" Match="NavLinkMatch.All" IconColor="Color.Default">@Loc["AdminNavMenu_Home"]</MudNavLink>
                }

                @* --- CLAIMS --- *@
                @if (_permissions.Contains(EmployeePermissions.AdminInvoices))
                {
                    <MudText Typo="Typo.caption" Class="mud-text-secondary px-3 py-2 d-block mt-4">@Loc["AdminNavMenu_Claims"]</MudText>
                    <MudNavLink Href="/employee/invoices" Icon="@Icons.Material.Filled.Receipt" IconColor="Color.Default">@Loc["AdminNavMenu_Invoices"]</MudNavLink>
                }

                @* --- USERS & PAYMENTS --- *@
                @if (_permissions.Contains(EmployeePermissions.AdminUsers) || _permissions.Contains(EmployeePermissions.AdminClients) ||
                     _permissions.Contains(EmployeePermissions.AdminSubscriptionPayments) || _permissions.Contains(EmployeePermissions.AdminPartners) ||
                     _permissions.Contains(EmployeePermissions.AdminInsurancePartners) || _permissions.Contains(EmployeePermissions.AdminPartnerBanks) ||
                     _permissions.Contains(EmployeePermissions.AdminTaxOffices))
                {
                    <MudText Typo="Typo.caption" Class="mud-text-secondary px-3 py-2 d-block mt-4">@Loc["AdminNavMenu_UsersAndPayments"]</MudText>
                    @if (_permissions.Contains(EmployeePermissions.AdminUsers))
                    {
                        <MudNavLink Href="/employee/users" Icon="@Icons.Material.Filled.SupervisorAccount" IconColor="Color.Default">@Loc["AdminNavMenu_User"]</MudNavLink>
                    }
                    @if (_permissions.Contains(EmployeePermissions.AdminClients))
                    {
                        <MudNavLink Href="/employee/clients" Icon="@Icons.Material.Filled.Person" IconColor="Color.Default">@Loc["AdminNavMenu_Clients"]</MudNavLink>
                    }
                    @if (_permissions.Contains(EmployeePermissions.AdminSubscriptionPayments))
                    {
                        <MudNavLink Href="/employee/subscription-payments" Icon="@Icons.Material.Filled.Payments" IconColor="Color.Default">@Loc["AdminNavMenu_SubscriptionPayments"]</MudNavLink>
                    }
                    @if (_permissions.Contains(EmployeePermissions.AdminPartners))
                    {
                        <MudNavLink Href="/employee/partners" Icon="@Icons.Material.Filled.Handshake" IconColor="Color.Default">@Loc["AdminNavMenu_Partners"]</MudNavLink>
                    }
                    @if (_permissions.Contains(EmployeePermissions.AdminInsurancePartners))
                    {
                        <MudNavLink Href="/employee/insurance-partners" Icon="@Icons.Material.Filled.Security" IconColor="Color.Default">@Loc["AdminNavMenu_InsurancePartners"]</MudNavLink>
                    }
                    @if (_permissions.Contains(EmployeePermissions.AdminPartnerBanks))
                    {
                        <MudNavLink Href="/employee/partner-banks" Icon="@Icons.Material.Filled.AccountBalance" IconColor="Color.Default">@Loc["AdminNavMenu_PartnerBanks"]</MudNavLink>
                    }
                    @if (_permissions.Contains(EmployeePermissions.AdminTaxOffices))
                    {
                        <MudNavLink Href="/employee/tax-offices" Icon="@Icons.Material.Filled.Business" IconColor="Color.Default">@Loc["AdminNavMenu_TaxOffices"]</MudNavLink>
                    }
                }

                @* --- BONIX --- *@
                @if (_permissions.Contains(EmployeePermissions.AdminCreditCheck) || _permissions.Contains(EmployeePermissions.AdminHistory))
                {
                    <div class="mt-6 mx-2 px-2">
                        <img src="images/Bonix.png" style="height: 24px; width: auto;" alt="Bonix" />
                    </div>
                    <MudNavMenu Margin="Margin.None" Color="Color.Primary" Rounded="true" Class="navmenu__list mb-6">
                        @if (_permissions.Contains(EmployeePermissions.AdminCreditCheck))
                        {
                            <MudNavLink Href="/employee/company-checks" Icon="@Icons.Material.Filled.Search" Match="NavLinkMatch.All" IconColor="Color.Error">@Loc["NavMenu_CreditCheck"]</MudNavLink>
                        }
                        @if (_permissions.Contains(EmployeePermissions.AdminHistory))
                        {
                            <MudNavLink Href="/employee/company-checks/history" Icon="@Icons.Material.Filled.History" Match="NavLinkMatch.All" IconColor="Color.Error">@Loc["NavMenu_History"]</MudNavLink>
                        }
                    </MudNavMenu>
                }

                @* --- SYSTEM --- *@
                @if (_permissions.Contains(EmployeePermissions.AdminSubscriptions) || _permissions.Contains(EmployeePermissions.AdminInvoiceStages) ||
                     _permissions.Contains(EmployeePermissions.AdminSettings))
                {
                    <MudText Typo="Typo.caption" Class="mud-text-secondary px-3 py-2 d-block mt-4">@Loc["AdminNavMenu_System"]</MudText>
                    @if (_permissions.Contains(EmployeePermissions.AdminSubscriptions))
                    {
                        <MudNavLink Href="/employee/subscriptions" Icon="@Icons.Material.Filled.Subscriptions" IconColor="Color.Default">@Loc["AdminNavMenu_Subscriptions"]</MudNavLink>
                    }
                    @if (_permissions.Contains(EmployeePermissions.AdminInvoiceStages))
                    {
                        <MudNavLink Href="/employee/invoice/stages" Icon="@Icons.Material.Filled.Timeline" IconColor="Color.Default">@Loc["AdminNavMenu_InvoiceStages"]</MudNavLink>
                    }
                    @if (_permissions.Contains(EmployeePermissions.AdminSettings))
                    {
                        <MudNavLink Href="/employee/settings" Icon="@Icons.Material.Filled.Settings" IconColor="Color.Default">@Loc["AdminNavMenu_Settings"]</MudNavLink>
                    }
                }

            </MudNavMenu>
        </div>
    </div>
</MudDrawer>
