@page "/partner-portal/sub-partners"
@rendermode InteractiveServer
@using Oikos.Common.Resources
@using Oikos.Application.Services.Partner.Models

<div class="partner-subpartners pb-10">

    <div class="sp-page-header mb-6">
        <div>
            <MudText Typo="Typo.h4" Class="sp-page-title">@Loc["PartnerSub_Title"]</MudText>
            <MudText Typo="Typo.body1" Class="mud-text-secondary">@Loc["PartnerSub_Subtitle"]</MudText>
        </div>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="@OpenCreateDialog"
                   Class="sp-add-btn">
            @Loc["PartnerSub_NewButton"]
        </MudButton>
    </div>

    @if (_isLoading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
    }
    else
    {
        <MudPaper Elevation="0" Class="sp-card rounded-xl">
            <div class="sp-card-header">
                <MudText Typo="Typo.h6" Class="sp-card-title">Sub-Partner</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary">
                    @string.Format(Loc["PartnerSub_Count"], _subPartners.Count)
                </MudText>
            </div>

            @if (_subPartners.Count == 0)
            {
                <div class="sp-empty">
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">@Loc["PartnerSub_Empty"]</MudText>
                </div>
            }
            else
            {
                @foreach (var sp in _subPartners)
                {
                    <div class="sp-row">
                        <div class="sp-row-left">
                            <div class="sp-avatar">
                                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                            </div>
                            <div class="sp-info">
                                <span class="sp-name">@sp.Name</span>
                                <div class="sp-meta">
                                    @if (!string.IsNullOrWhiteSpace(sp.ContactEmail))
                                    {
                                        <span class="sp-email">@sp.ContactEmail</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(sp.Notes))
                                    {
                                        <span class="sp-notes">@sp.Notes</span>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="sp-row-right">
                            <div class="sp-code-row">
                                <span class="sp-code">@sp.Code</span>
                                <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                               Size="Size.Small"
                                               Class="sp-copy-btn"
                                               OnClick="@(() => CopyCodeAsync(sp.Code))"
                                               Title="@Loc["PartnerSub_CopyCode"]" />
                            </div>
                            <span class="sp-status @(sp.IsActive ? "sp-status-active" : "sp-status-inactive")">
                                @(sp.IsActive ? Loc["PartnerRec_StatusActive"] : Loc["PartnerSub_Inactive"])
                            </span>
                            <span class="sp-date">@sp.CreatedAt.ToString("dd.MM.yyyy")</span>
                        </div>
                    </div>
                }
            }
        </MudPaper>
    }
</div>

@* Create Sub-Partner Dialog *@
<MudDialog @bind-Visible="_showDialog" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">@Loc["PartnerSub_DialogTitle"]</MudText>
        <MudText Typo="Typo.caption" Class="mud-text-secondary">@Loc["PartnerSub_DialogSubtitle"]</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3" Class="pt-1">
            <MudTextField @bind-Value="_form.Name"
                          Label="@Loc["PartnerSub_FieldName"]"
                          Placeholder="Max Mustermann"
                          Variant="Variant.Outlined"
                          Required="true" />

            <MudTextField @bind-Value="_form.Business"
                          Label="@Loc["PartnerSub_FieldBusiness"]"
                          Placeholder="Musterfirma GmbH"
                          Variant="Variant.Outlined" />

            <MudTextField @bind-Value="_form.Email"
                          Label="@Loc["PartnerSub_FieldEmail"]"
                          Placeholder="partner@muster.de"
                          Variant="Variant.Outlined"
                          InputType="InputType.Email"
                          Required="true" />

            <MudTextField @bind-Value="_form.PhoneNumber"
                          Label="@Loc["PartnerSub_FieldPhone"]"
                          Placeholder="+49 123 456789"
                          Variant="Variant.Outlined" />

            <MudGrid Spacing="2">
                <MudItem xs="6">
                    <MudSelect @bind-Value="_form.CommissionType"
                               Label="@Loc["PartnerSub_FieldCommissionType"]"
                               Variant="Variant.Outlined">
                        <MudSelectItem Value="@("Monthly")">@Loc["PartnerDialog_CommissionMonthly"]</MudSelectItem>
                        <MudSelectItem Value="@("Yearly")">@Loc["PartnerDialog_CommissionYearly"]</MudSelectItem>
                        <MudSelectItem Value="@("OneTime")">@Loc["PartnerDialog_CommissionOneTime"]</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="6">
                    <MudNumericField @bind-Value="_form.CommissionRate"
                                     Label="@Loc["PartnerSub_FieldCommissionRate"]"
                                     Variant="Variant.Outlined"
                                     Min="0"
                                     Max="100"
                                     Format="N2"
                                     Adornment="Adornment.End"
                                     AdornmentText="%" />
                </MudItem>
            </MudGrid>

            <MudTextField @bind-Value="_form.Password"
                          Label="@Loc["PartnerSub_FieldPassword"]"
                          InputType="InputType.Password"
                          Variant="Variant.Outlined"
                          Required="true" />

            @if (!string.IsNullOrWhiteSpace(_createError))
            {
                <MudAlert Severity="Severity.Error" Dense="true">@_createError</MudAlert>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@CloseDialog" Variant="Variant.Text" Color="Color.Secondary">@Loc["Cancel"]</MudButton>
        <MudButton OnClick="@CreateSubPartnerAsync"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="_isSaving">
            @if (_isSaving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            @Loc["PartnerSub_CreateButton"]
        </MudButton>
    </DialogActions>
</MudDialog>
