@page "/partner-portal/recommendations"
@rendermode InteractiveServer
@using Oikos.Common.Resources
@using Oikos.Application.Services.Partner.Models

<div class="partner-recommendations pb-10">

    <div class="rec-page-header mb-6">
        <div>
            <MudText Typo="Typo.h4" Class="rec-page-title">@Loc["PartnerRec_Title"]</MudText>
            <MudText Typo="Typo.body1" Class="mud-text-secondary">@Loc["PartnerRec_Subtitle"]</MudText>
        </div>
    </div>

    @if (_isLoading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
    }
    else
    {
        <MudPaper Elevation="0" Class="rec-card rounded-xl">
            <div class="rec-card-header">
                <MudText Typo="Typo.h6" Class="rec-card-title">@Loc["PartnerRec_SectionTitle"]</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary">
                    @string.Format(Loc["PartnerRec_SectionCount"], _recommendations.Count)
                </MudText>
            </div>

            @if (_recommendations.Count == 0)
            {
                <div class="rec-empty">
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">@Loc["PartnerRec_Empty"]</MudText>
                </div>
            }
            else
            {
                @foreach (var rec in _recommendations)
                {
                    <div class="rec-row">
                        <div class="rec-row-left">
                            <div class="rec-avatar">
                                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                            </div>
                            <div class="rec-info">
                                <span class="rec-name">@rec.Name</span>
                                <div class="rec-meta">
                                    @if (!string.IsNullOrWhiteSpace(rec.CustomerNumber))
                                    {
                                        <span class="rec-customer-no">@Loc["PartnerRec_CustomerNo"].: @rec.CustomerNumber</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(rec.PlanName))
                                    {
                                        <span class="rec-plan-chip">@rec.PlanName</span>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="rec-row-right">
                            @if (rec.SubscriptionStatus != "none")
                            {
                                <span class="rec-status-chip rec-status-@rec.SubscriptionStatus">
                                    @GetStatusLabel(rec.SubscriptionStatus)
                                </span>
                            }
                            <span class="rec-billing">@GetBillingLabel(rec.BillingInterval)</span>
                            @if (rec.ExpirationDate.HasValue)
                            {
                                <span class="rec-date">
                                    <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Style="font-size:13px; vertical-align:middle; margin-right:2px;" />
                                    @rec.ExpirationDate.Value.ToString("dd.MM.yyyy")
                                </span>
                            }
                        </div>
                    </div>
                }
            }
        </MudPaper>
    }
</div>
