@using Oikos.Application.Common
@using Oikos.Application.Constants
@using Oikos.Application.Services.User.Models
@using Oikos.Common.Constants
@using Oikos.Application.Services.Partner.Models
@using Oikos.Application.Services.Subscription.Models
@using Oikos.Common.Resources

<MudDialog>
    <DialogContent>
        @if (_loading)
        {
            <MudProgressCircular Indeterminate="true" Class="mx-auto d-block" />
        }
        else
        {
            <EditForm Model="_model" OnValidSubmit="Submit" style="width:100%;">
                <DataAnnotationsValidator />
                <MudGrid Spacing="3">

                    @* Row 1: Company (full width) *@
                    <MudItem xs="12">
                        <MudTextField T="string" @bind-Value="_model.Company" Variant="Variant.Outlined" Margin="Margin.Dense"
                                      Label="@Loc["UserPage_Company"]" For="@(() => _model.Company)" />
                    </MudItem>

                    @* Row 2: Gender + Academic Title *@
                    <MudItem xs="6">
                        <MudSelect T="string" @bind-Value="_model.Gender" Variant="Variant.Outlined" Margin="Margin.Dense"
                                   Label="@Loc["UserPage_GenderLabel"]" For="@(() => _model.Gender)" Placeholder="@Loc["UserPage_GenderPlaceholder"]">
                            <MudSelectItem Value="@NameConstants.Genders.Female">@Loc["UserPage_GenderOptionFemale"]</MudSelectItem>
                            <MudSelectItem Value="@NameConstants.Genders.Male">@Loc["UserPage_GenderOptionMale"]</MudSelectItem>
                            <MudSelectItem Value="@NameConstants.Genders.Diverse">@Loc["UserPage_GenderOptionDiverse"]</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="6">
                        <MudSelect T="string" @bind-Value="_model.AcademicTitle" Variant="Variant.Outlined" Margin="Margin.Dense"
                                   Label="@Loc["UserPage_TitleLabel"]" Clearable="true" Placeholder="@Loc["UserPage_TitlePlaceholder"]">
                            <MudSelectItem Value="@NameConstants.Titles.Dr">@Loc["UserPage_TitleOptionDr"]</MudSelectItem>
                            <MudSelectItem Value="@NameConstants.Titles.Prof">@Loc["UserPage_TitleOptionProf"]</MudSelectItem>
                            <MudSelectItem Value="@NameConstants.Titles.ProfDr">@Loc["UserPage_TitleOptionProfDr"]</MudSelectItem>
                        </MudSelect>
                    </MudItem>

                    @* Row 3: Full Name + Email *@
                    <MudItem xs="6">
                        <MudTextField T="string" @bind-Value="_model.RealName" Variant="Variant.Outlined" Margin="Margin.Dense"
                                      Label="@Loc["UserPage_FullName"]" For="@(() => _model.RealName)" />
                    </MudItem>
                    <MudItem xs="6">
                        <MudTextField T="string" @bind-Value="_model.Email" Variant="Variant.Outlined" Margin="Margin.Dense"
                                      Label="@Loc["UserPage_Email"]" For="@(() => _model.Email)" />
                    </MudItem>

                    @* Row 4: Partner + Role *@
                    @if (!_isEmployeeRole && !_isAdminRole && !_isPartnerRole)
                    {
                        <MudItem xs="6">
                            <MudSelect T="int?" @bind-Value="_model.PartnerId" Variant="Variant.Outlined" Margin="Margin.Dense"
                                       Label="@Loc["UserPage_PartnerLabel"]" Placeholder="@Loc["UserPage_PartnerPlaceholder"]" Clearable="true">
                                <MudSelectItem Value="@((int?)null)">@Loc["UserPage_NoPartnerOption"]</MudSelectItem>
                                @foreach (var partner in _partners)
                                {
                                    <MudSelectItem Value="@((int?)partner.Id)">@($"{partner.Name} ({partner.Code})")</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                    }
                    <MudItem xs="6">
                        <MudSelect T="int?" Value="_model.RoleId" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="_isEmployeeRole"
                                   Label="@Loc["UserPage_RoleLabel"]" Placeholder="@Loc["UserPage_RolePlaceholder"]"
                                   ValueChanged="OnRoleChanged">
                            @foreach (var role in _roles)
                            {
                                <MudSelectItem Value="@((int?)role.Id)">@role.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    @* Employee dropdown — shown only when a non-employee role is selected *@
                    @if (!_isEmployeeRole && _employees.Count > 0 && !_isPartnerRole && !_isAdminRole)
                    {
                        <MudItem xs="12">
                            <MudSelect T="int?" @bind-Value="_model.AssignedEmployeeId" Variant="Variant.Outlined" Margin="Margin.Dense"
                                       Label="@Loc["UserPage_AssignedEmployee"]" Placeholder="@Loc["UserPage_AssignedEmployeePlaceholder"]" Clearable="true">
                                <MudSelectItem Value="@((int?)null)">@Loc["UserPage_NoEmployeeOption"]</MudSelectItem>
                                @foreach (var employee in _employees)
                                {
                                    <MudSelectItem Value="@((int?)employee.Id)">@employee.Name</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                    }

                    @* Employee Permissions — shown only when Employee role is selected *@
                    @if (_isEmployeeRole)
                    {
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Style="font-weight:600;">@Loc["UserPage_EmployeePermissions"]</MudText>
                        </MudItem>

                        @* Home *@
                        <MudItem xs="12">
                            <MudPaper Elevation="0" Class="pa-2 rounded-lg" Style="border:1px solid #e0e0e0;">
                                <MudCheckBox T="bool" Value="_selectedPermissions.Contains(EmployeePermissions.AdminHome)"
                                             ValueChanged="v => OnPermissionToggled(EmployeePermissions.AdminHome, v)"
                                             Label="@Loc["AdminNavMenu_Home"]" Color="Color.Primary" Dense="true" />
                            </MudPaper>
                        </MudItem>

                        @* Claims *@
                        <MudItem xs="12">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary mb-1 d-block">@Loc["AdminNavMenu_Claims"]</MudText>
                            <MudPaper Elevation="0" Class="pa-2 rounded-lg" Style="border:1px solid #e0e0e0;">
                                <MudCheckBox T="bool" Value="_selectedPermissions.Contains(EmployeePermissions.AdminInvoices)"
                                             ValueChanged="v => OnPermissionToggled(EmployeePermissions.AdminInvoices, v)"
                                             Label="@Loc["AdminNavMenu_Invoices"]" Color="Color.Primary" Dense="true" />
                            </MudPaper>
                        </MudItem>

                        @* Users & Payments *@
                        <MudItem xs="12">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary mb-1 d-block">@Loc["AdminNavMenu_UsersAndPayments"]</MudText>
                            <MudPaper Elevation="0" Class="pa-3 rounded-lg" Style="border:1px solid #e0e0e0; display:grid; grid-template-columns:1fr 1fr; gap:0;">
                                <MudCheckBox T="bool" Value="_selectedPermissions.Contains(EmployeePermissions.AdminUsers)"
                                             ValueChanged="v => OnPermissionToggled(EmployeePermissions.AdminUsers, v)"
                                             Label="@Loc["AdminNavMenu_User"]" Color="Color.Primary" Dense="true" />
                                <MudCheckBox T="bool" Value="_selectedPermissions.Contains(EmployeePermissions.AdminClients)"
                                             ValueChanged="v => OnPermissionToggled(EmployeePermissions.AdminClients, v)"
                                             Label="@Loc["AdminNavMenu_Clients"]" Color="Color.Primary" Dense="true" />
                                <MudCheckBox T="bool" Value="_selectedPermissions.Contains(EmployeePermissions.AdminSubscriptionPayments)"
                                             ValueChanged="v => OnPermissionToggled(EmployeePermissions.AdminSubscriptionPayments, v)"
                                             Label="@Loc["AdminNavMenu_SubscriptionPayments"]" Color="Color.Primary" Dense="true" />
                            </MudPaper>
                        </MudItem>

                        @* Bonix *@
                        <MudItem xs="12">
                            <div class="mb-1">
                                <img src="images/Bonix.png" style="height: 16px; width: auto;" alt="Bonix" />
                            </div>
                            <MudPaper Elevation="0" Class="pa-3 rounded-lg" Style="border:1px solid #e0e0e0; display:grid; grid-template-columns:1fr 1fr; gap:0;">
                                <MudCheckBox T="bool" Value="_selectedPermissions.Contains(EmployeePermissions.AdminCreditCheck)"
                                             ValueChanged="v => OnPermissionToggled(EmployeePermissions.AdminCreditCheck, v)"
                                             Label="@Loc["NavMenu_CreditCheck"]" Color="Color.Primary" Dense="true" />
                                <MudCheckBox T="bool" Value="_selectedPermissions.Contains(EmployeePermissions.AdminHistory)"
                                             ValueChanged="v => OnPermissionToggled(EmployeePermissions.AdminHistory, v)"
                                             Label="@Loc["NavMenu_History"]" Color="Color.Primary" Dense="true" />
                            </MudPaper>
                        </MudItem>

                        @* System *@
                        <MudItem xs="12">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary mb-1 d-block">@Loc["AdminNavMenu_System"]</MudText>
                            <MudPaper Elevation="0" Class="pa-3 rounded-lg" Style="border:1px solid #e0e0e0; display:grid; grid-template-columns:1fr 1fr; gap:0;">
                                <MudCheckBox T="bool" Value="_selectedPermissions.Contains(EmployeePermissions.AdminSubscriptions)"
                                             ValueChanged="v => OnPermissionToggled(EmployeePermissions.AdminSubscriptions, v)"
                                             Label="@Loc["AdminNavMenu_Subscriptions"]" Color="Color.Primary" Dense="true" />
                                <MudCheckBox T="bool" Value="_selectedPermissions.Contains(EmployeePermissions.AdminInvoiceStages)"
                                             ValueChanged="v => OnPermissionToggled(EmployeePermissions.AdminInvoiceStages, v)"
                                             Label="@Loc["AdminNavMenu_InvoiceStages"]" Color="Color.Primary" Dense="true" />
                                <MudCheckBox T="bool" Value="_selectedPermissions.Contains(EmployeePermissions.AdminSettings)"
                                             ValueChanged="v => OnPermissionToggled(EmployeePermissions.AdminSettings, v)"
                                             Label="@Loc["AdminNavMenu_Settings"]" Color="Color.Primary" Dense="true" />
                                <MudCheckBox T="bool" Value="_selectedPermissions.Contains(EmployeePermissions.AdminPartners)"
                                             ValueChanged="v => OnPermissionToggled(EmployeePermissions.AdminPartners, v)"
                                             Label="@Loc["AdminNavMenu_Partners"]" Color="Color.Primary" Dense="true" />
                                <MudCheckBox T="bool" Value="_selectedPermissions.Contains(EmployeePermissions.AdminInsurancePartners)"
                                             ValueChanged="v => OnPermissionToggled(EmployeePermissions.AdminInsurancePartners, v)"
                                             Label="@Loc["AdminNavMenu_InsurancePartners"]" Color="Color.Primary" Dense="true" />
                                <MudCheckBox T="bool" Value="_selectedPermissions.Contains(EmployeePermissions.AdminPartnerBanks)"
                                             ValueChanged="v => OnPermissionToggled(EmployeePermissions.AdminPartnerBanks, v)"
                                             Label="@Loc["AdminNavMenu_PartnerBanks"]" Color="Color.Primary" Dense="true" />
                                <MudCheckBox T="bool" Value="_selectedPermissions.Contains(EmployeePermissions.AdminTaxOffices)"
                                             ValueChanged="v => OnPermissionToggled(EmployeePermissions.AdminTaxOffices, v)"
                                             Label="@Loc["AdminNavMenu_TaxOffices"]" Color="Color.Primary" Dense="true" />
                            </MudPaper>
                        </MudItem>
                    }

                    @* Plan selection — shown only for User/Client role *@
                    @if (!_isEmployeeRole && !_isAdminRole && !_isPartnerRole && _plans.Count > 0)
                    {
                        <MudItem xs="8">
                            <MudSelect T="int?" @bind-Value="_model.PlanId" Variant="Variant.Outlined" Margin="Margin.Dense"
                                       Label="@Loc["UserPage_SubscriptionPlan"]" Placeholder="@Loc["UserPage_NoPlanOption"]" Clearable="true">
                                <MudSelectItem Value="@((int?)null)">@Loc["UserPage_NoPlanOption"]</MudSelectItem>
                                @foreach (var plan in _plans)
                                {
                                    <MudSelectItem Value="@((int?)plan.Id)">@plan.Name</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="4">
                            <MudSelect T="string" @bind-Value="_model.BillingInterval" Variant="Variant.Outlined" Margin="Margin.Dense"
                                       Label="@Loc["UserPage_BillingInterval"]" Disabled="@(!_model.PlanId.HasValue)">
                                <MudSelectItem Value="@("monthly")">@Loc["UserPage_BillingMonthly"]</MudSelectItem>
                                <MudSelectItem Value="@("yearly")">@Loc["UserPage_BillingYearly"]</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                    }

                    @* Row: Customer Number + Phone *@
                    @if (!(_isEmployeeRole || _isAdminRole || _isPartnerRole))
                    {
                        <MudItem xs="6">
                            <MudTextField T="string" @bind-Value="_model.CustomerNumber" Variant="Variant.Outlined" Margin="Margin.Dense"
                                          Label="@Loc["UserPage_CustomerNumberLabel"]" For="@(() => _model.CustomerNumber)"
                                          HelperText="@Loc["UserPage_CustomerNumberHelper"]" />
                        </MudItem>
                    }

                    @if (_isEmployeeRole || _isAdminRole || _isPartnerRole)
                    {
                        <MudItem xs="12">
                            <MudTextField T="string" @bind-Value="_model.PhoneNumber" Variant="Variant.Outlined" Margin="Margin.Dense"
                                          Label="@Loc["UserPage_Phone"]" For="@(() => _model.PhoneNumber)" />
                        </MudItem>
                    }
                    else
                    {
                        <MudItem xs="6">
                            <MudTextField T="string" @bind-Value="_model.PhoneNumber" Variant="Variant.Outlined" Margin="Margin.Dense"
                                          Label="@Loc["UserPage_Phone"]" For="@(() => _model.PhoneNumber)" />
                        </MudItem>
                    }
                    @* Submit *@
                    <MudItem xs="12">
                        <div class="d-flex justify-end">
                            <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Medium"
                                       ButtonType="ButtonType.Submit" StartIcon="@Icons.Material.Filled.Upload">@Loc["UserPage_SubmitText"]</MudButton>
                        </div>
                    </MudItem>

                </MudGrid>
            </EditForm>
        }
    </DialogContent>
</MudDialog>
